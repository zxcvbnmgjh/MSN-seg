# ===========================
# Strategy: Ignore all data files FIRST, then explicitly allow code
# The key is: *.png and other data extensions are ignored ABOVE
# So even if we allow SN+project/**/*, the *.png files inside are still ignored
# because .gitignore rules are processed top-to-bottom and the last matching rule wins
# BUT: a file will be ignored if ANY parent directory is ignored
#
# So we need to:
# 1. Ignore data directories completely (MSN-TCSeg_dataset/, etc.)
# 2. Ignore data file extensions (*.png, *.pt, etc.) everywhere
# 3. Allow Python files in project directories
# ===========================

# Allow Python code files in project directories
!SN+project/**/*.py
!SN+project/**/*.md
!SN+project/**/*.ipynb
!SN+project/**/*.sh
!SN+project/**/requirements*.txt
!SN+project/**/*.yml
!SN+project/**/*.yaml

!new_models_doing/**/*.py
!new_models_doing/**/*.md
!new_models_doing/**/*.ipynb
!new_models_doing/**/*.sh
!new_models_doing/**/requirements*.txt
!new_models_doing/**/*.yml
!new_models_doing/**/*.yaml

!paper_prepare/**/*.py
!paper_prepare/**/*.md
!paper_prepare/**/*.ipynb
!paper_prepare/**/*.sh
!paper_prepare/**/requirements*.txt
# paper_prepare data files (json, txt, xlsx are data)
paper_prepare/**/*.json
paper_prepare/**/*.txt
paper_prepare/**/*.xlsx
paper_prepare/**/*.xls
paper_prepare/**/*.csv

!Ultrasound_examination/**/*.py
!Ultrasound_examination/**/*.md
!Ultrasound_examination/**/*.ipynb
!Ultrasound_examination/**/*.sh
!Ultrasound_examination/**/requirements*.txt

!stu_net/**/*.py
!stu_net/**/*.md
!stu_net/**/*.sh

# Allow project root folders to be traversed
!SN+project/
!new_models_doing/
!paper_prepare/
!Ultrasound_examination/
!stu_net/
